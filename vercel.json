{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "node_modules/@napi-rs/canvas/**",
          "node_modules/@sparticuz/chromium/**",
          "node_modules/pdf-to-img/**",
          "node_modules/pdfjs-dist/**",
          "node_modules/puppeteer-core/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
